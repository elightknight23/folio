# Supabase — public keys, safe to expose in the browser
# Get these from your project's Settings > API page
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Backend API URL
# Local dev: http://localhost:8000
# Production: update to your Render service URL (Sprint 10)
VITE_API_URL=http://localhost:8000
